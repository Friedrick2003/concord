{
  "name": "concord",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:all": "npm run build --workspaces",
    "dev:all": "npm run dev --workspaces",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w concord-sync-server"
  }
}
